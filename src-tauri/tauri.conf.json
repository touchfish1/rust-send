{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/main/tauri.conf.schema.json",
  "productName": "rust-send",
  "version": "0.2.0",
  "identifier": "dev.rust-send.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "rust-send",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzMEQwNUYyRDE0RjU1NkYKUldSdlZVL1I4Z1VOUXlvTGR1S2dEMnZDcFZjU2ltajR6cndYV0JoaEQwZzdua0s2RFU5NmhGRWwK",
      "endpoints": [
        "https://github.com/touchfish1/rust-send/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
